# Standalone booking server env (server/.env). Loaded via systemd EnvironmentFile.
PORT=8787

# Point at the local self-hosted Supabase REST gateway (Kong) and the
# service-role key from your supabase/docker/.env.
SUPABASE_URL=http://localhost:8000
SUPABASE_SERVICE_ROLE_KEY=your-self-hosted-service-role-key

# Restrict CORS to your site in production (instead of *).
CORS_ORIGIN=https://albertkstudio.agenbord.co

STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
RESEND_API_KEY=re_xxx
SALON_EMAIL=info@albertkstudio.com
FROM_EMAIL=Albert K Studio <bookings@albertkstudio.com>
