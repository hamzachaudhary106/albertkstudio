# Frontend (Vite) — safe to expose, prefixed with VITE_
# Self-hosted on the VPS, the Supabase API is served under /supabase on the
# same host. Managed Supabase instead? Use https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_URL=https://albertkstudio.agenbord.co/supabase
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ---------------------------------------------------------------------------
# The values below are NOT used by the frontend. Set them as Supabase Edge
# Function secrets (see supabase/README.md), never in this file in production:
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_xxx ...
#
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# RESEND_API_KEY=re_xxx
# SALON_EMAIL=info@albertkstudio.com
# FROM_EMAIL=Albert K Studio <bookings@albertkstudio.com>
